# EasyTier SSH Jumpserver 示例配置文件
# 复制此文件为 .env 并修改相应的值

# SSH 配置
SSH_USER=root
SSH_PASSWORD=YourSecurePassword123

# EasyTier 配置（方式 1: 通过 ET_CONFIG_SERVER 连接到 Web Console，推荐）
ET_CONFIG_SERVER=ws://api.easytier.hinswu.top:0/HINS
ET_MACHINE_ID=HINS-UZ801-SSH01

# 方式 2: 直接通过环境变量配置（不通过 Web Console）
# 注释掉 ET_CONFIG_SERVER，使用下面的配置
# EASYTIER_NETWORK_NAME=myjumpserver
# EASYTIER_NETWORK_SECRET=myjumpserver
# EASYTIER_SERVERS=tcp://your-public-ip:11010

# 时区配置
TZ=Asia/Shanghai
